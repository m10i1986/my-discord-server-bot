{
    "name": "mind-chat-bot",
    "version": "1.0.0",
    "description": "Mind Chat Bot",
    "private": true,
    "scripts": {
        "start": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 start ecosystem.config.cjs",
        "stop": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 stop ecosystem.config.cjs",
        "restart": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 restart ecosystem.config.cjs",
        "reload": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 reload ecosystem.config.cjs",
        "delete": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 delete ecosystem.config.cjs",
        "status": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 list",
        "monit": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 monit",
        "setup:journald": "PM2_HOME=\"$INIT_CWD/.pm2\" pm2 install pm2-journald",
        "build:all": "pnpm --filter '*' run build"
    },
    "devDependencies": {
        "pm2": "^5.4.3"
    },
    "packageManager": "pnpm@10.29.3"
}
